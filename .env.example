# WorldOfTaxanomy - environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret - must be at least 32 characters
# Generate one with: python3 -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=your-secret-at-least-32-chars-long

# Email address for session completion reports (sent via Gmail MCP)
REPORT_EMAIL=your@email.com
