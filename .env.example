# WorldOfTaxanomy - environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret - must be at least 32 characters
# Generate one with: python3 -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=your-secret-at-least-32-chars-long

# Email address for session completion reports (sent via Gmail MCP)
REPORT_EMAIL=your@email.com

# Comma-separated list of allowed CORS origins for the API.
# Leave unset in local dev to allow http://localhost:3000 and http://127.0.0.1:3000.
# In production, set to your frontend origin(s), e.g.:
#   ALLOWED_ORIGINS=https://worldoftaxonomy.com,https://www.worldoftaxonomy.com
ALLOWED_ORIGINS=

# Optional: Sentry DSNs for backend + frontend error tracking.
# Leave unset to disable Sentry (no-op init).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# LLM providers. All LLM calls in the project go through
# world_of_taxonomy.llm_client. Both providers speak OpenAI-compatible chat
# completions, so only the base URL, key, and default model differ.
#
# Preference order: Ollama Cloud (primary) -> OpenRouter (fallback).
# The fallback kicks in only when Ollama is not configured OR when an Ollama
# call raises a transient HTTP error. Either provider alone is sufficient.
#
# Used by:
#   - POST /api/v1/systems/{id}/nodes/{code}/generate  (AI taxonomy suggestions)
#   - POST /api/v1/classify                            (keyword-expansion fallback)
# With neither key: generate endpoint returns 503; classify silently skips
# the LLM fallback.
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=https://ollama.com/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
